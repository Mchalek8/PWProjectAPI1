{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "Node",

    "types": ["node", "@playwright/test"],

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "tests",
    "src",
    "**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}